# AWS credentials — required for Glue/S3/Bedrock features
AWS_ACCESS_KEY_ID=your-access-key-here
AWS_SECRET_ACCESS_KEY=your-secret-key-here

# Region for Glue + S3 (where the demo jobs live)
AWS_GLUE_REGION=ap-south-2

# Region for Bedrock (Claude + Titan)
AWS_BEDROCK_REGION=ap-south-2

# Inference profile ID — global. prefix required in ap-south-2
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-5-20250929-v1:0
